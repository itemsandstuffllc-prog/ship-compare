{
  "manifest_version": 3,
  "name": "Ship Compare for eBay + Pirate Ship",
  "version": "0.4.0",
  "description": "See live Pirate Ship postage next to your eBay label price, with a one-click handoff that carries over the order, weight, and size.",
  "permissions": ["clipboardWrite", "storage"],
  "host_permissions": [
    "https://ship.pirateship.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/sh/lbl*",
        "https://www.ebay.com/ship*",
        "https://www.ebay.com/sl/prnt*",
        "https://www.ebay.com/sl/*label*"
      ],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.ebay.com/sh/lbl*",
        "https://www.ebay.com/ship*",
        "https://www.ebay.com/sl/prnt*",
        "https://www.ebay.com/sl/*label*"
      ],
      "js": ["src/ebay-adapter.js", "src/content.js"],
      "css": ["src/panel.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://ship.pirateship.com/*"],
      "js": ["src/pirateship.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png", "icons/icon128.png"],
      "matches": ["https://www.ebay.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
